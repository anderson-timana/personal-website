---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page not found | Anderson Timana" description="It seems that you got lost. No problem, here are some links that can help you.">
  <Navigation />
  
  <main id="main-content" class="pt-24 min-h-screen flex flex-col items-center">
    
    <section class="w-full max-w-4xl mx-auto p-4 md:p-8 flex-grow flex items-center justify-center">
      <div class="text-center">
        <h1 class="text-xs md:text-sm font-body font-medium uppercase tracking-[0.1em] text-accent mb-6">
          Page not found
        </h1>
        
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold tracking-tight leading-tight text-text-heading mb-6">
          404
        </h2>
        
        <p class="text-text-body text-lg leading-relaxed max-w-2xl mx-auto mb-8">
          It seems that you got lost. No problem, here are some links that can help you:
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 justify-center">
          <a href="/free-tools" class="btn bg-accent text-primary-base px-8 py-4 hover:bg-white inline-flex items-center justify-center">
            Check my tools
          </a>
          <a href="/" class="btn bg-transparent border border-white text-text-heading px-8 py-4 hover:border-accent hover:text-accent inline-flex items-center justify-center">
            Return Home
          </a>
        </div>
      </div>
    </section>
    
  </main>
  
  <Footer />
</Layout>