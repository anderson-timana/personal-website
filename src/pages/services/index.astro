---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const services = await getCollection('services', ({ data }) => {
  return data.isDraft !== true && data.audience === 'fractional-cto';
});

services.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
---

<Layout title="Strategic Growth & Digital Consulting | Anderson Timana" description="Explore my fixed-price strategic growth consulting and digital infrastructure units.">
  <Navigation />
  
  <main id="main-content" class="pt-24 min-h-screen flex flex-col">
    <section class="p-4 md:p-8 max-w-5xl mx-auto w-full flex-grow">
      
      <!-- Menu Intent (H1 | VR3) -->
      <h1 class="text-xs md:text-sm font-body font-medium uppercase tracking-[0.1em] text-accent mb-6 text-center">
        Growth & Digital Infrastructure Consulting Services
      </h1>
      
      <h2 class="text-3xl md:text-5xl font-heading font-bold tracking-tight leading-tight text-text-heading mb-12 text-center">
        Fixed-price Strategic Units
      </h2>
      
      <!-- Service Horizontal Row Layout -->
      <ul class="flex flex-col gap-8" id="service-list">
        {services.map((service) => (
          <li class="service-item list-none">
            <a href={`/services/${service.slug}`} class="group border border-surface/50 bg-primary-base p-6 md:p-10 flex flex-col md:flex-row hover:border-accent/50 transition-colors gap-6 md:gap-12 relative overflow-hidden focus-visible:ring-4 focus-visible:ring-accent outline-none">
              
              <div class="md:w-1/3 flex flex-col justify-start">
                <h3 class="text-2xl md:text-3xl font-heading font-bold text-text-heading group-hover:text-accent transition-colors mb-4">
                  {service.data.serviceTitle}
                </h3>
                <div class="text-xl font-heading font-bold text-text-body">
                  {service.data.priceLabel}
                </div>
              </div>
              
              <div class="md:w-2/3 flex flex-col justify-center">
                <p class="text-lg text-text-body leading-relaxed mb-6">
                  {service.data.scope}
                </p>
                
                <div class="mt-auto inline-flex items-center text-accent font-bold uppercase tracking-widest text-sm group-hover:text-white transition-colors">
                  View Details
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-2 group-hover:translate-x-1 transition-transform" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </div>
              </div>
              
            </a>
          </li>
        ))}
      </ul>
    </section>

    <Footer />
  </main>
</Layout>