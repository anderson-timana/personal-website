---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

export async function getStaticPaths() {
  // Only include case studies intended for the main/fractional-cto audience
  const caseStudies = await getCollection('case-studies', ({ data }) => 
    !data.isDraft && data.showcase?.includes('main')
  );
  
  return caseStudies.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Breadcrumb logic for main audience
const breadcrumbRoot = { label: 'Home', href: '/' };
const breadcrumbItems = [
  { label: 'Case Studies', href: '/case-studies' },
  { label: entry.data.caseTitle }
];
---

<Layout title={`${entry.data.seoTitle} | Anderson Timana`} description={entry.data.metaDescription}>
  <Navigation />
  
  <main id="main-content" class="pt-24 min-h-screen flex flex-col">
    <article class="p-4 md:p-8 max-w-3xl mx-auto w-full flex-grow">
      
      <Breadcrumbs 
        root={breadcrumbRoot}
        items={breadcrumbItems}
      />

      <div class="flex items-center gap-4 my-8">
        {/* entry.data.liveSiteUrl && (
          <a href={entry.data.liveSiteUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-bold text-accent bg-transparent border border-accent rounded-full hover:bg-accent hover:text-surface transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
            Live Site
          </a>
        ) */}
        {/* entry.data.repoUrl && (
          <a href={entry.data.repoUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-bold text-text-muted bg-transparent border border-surface/50 rounded-full hover:bg-surface/50 hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
            Repository
          </a>
        ) */}
      </div>

      <div class="mb-12">
        <!-- SEO Intent (H1 | VR3) -->
        <h1 class="text-xs md:text-sm font-body font-bold uppercase tracking-[0.1em] text-accent mb-6">
          {entry.data.seoTitle}
        </h1>
        
        <!-- The Verdict (H2 | VR1) -->
        <h2 class="text-4xl md:text-6xl lg:text-[5rem] font-heading font-bold tracking-tight leading-[1.1] text-text-heading mb-8">
          {entry.data.verdict}
        </h2>
      </div>

      {entry.data.strategicAction && (
        <div class="p-6 md:p-8 bg-surface/20 border-l-4 border-accent mb-16">
          <h3 class="text-xl md:text-2xl font-heading font-bold text-text-heading mb-4">Strategic Action</h3>
          <p class="text-lg text-text-body">{entry.data.strategicAction}</p>
        </div>
      )}

      <div class="prose prose-invert prose-lg text-text-body mb-16">
        <Content />
      </div>

      <div class="mt-16 border-t border-surface/50 pt-8">
        <a href="/case-studies" class="text-accent hover:text-white uppercase tracking-widest font-bold text-sm inline-flex items-center gap-2 transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          Back to Case Studies
        </a>
      </div>
    </article>

    <Footer />
  </main>
</Layout>
