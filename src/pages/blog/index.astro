---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { wpFetch } from '../../utils/wpGraphql';

// Define the Post interface (matches your GraphQL query structure)
interface Post {
  title: string;
  slug: string;
  date: string;
  excerpt: string;
  featuredImage?: {
    node: {
      sourceUrl: string;
      altText: string;
    };
  };
}

// GraphQL query to fetch all posts using default WordPress fields
const postsQuery = `
  query GetPosts {
    posts(first: 100, where: { orderby: { field: DATE, order: DESC } }) {
      nodes {
        title
        slug
        date
        excerpt
        featuredImage {
          node {
            sourceUrl
            altText
          }
        }
      }
    }
  }
`;


const data = await wpFetch({ query: postsQuery });
const posts: Post[] = data?.posts?.nodes || [];

---

<Layout title="Blog | Anderson Timana" description="Insights, observations, and deep dives into digital infrastructure.">
  <Navigation />
  
  <main id="main-content" class="pt-24 min-h-screen flex flex-col">
    <section class="p-4 md:p-8 max-w-5xl mx-auto w-full flex-grow">
      
      <h1 class="text-xs md:text-sm font-body font-medium uppercase tracking-[0.1em] text-accent mb-6 text-center">
        Strategic Insights
      </h1>
      
      <h2 class="text-3xl md:text-5xl font-heading font-bold tracking-tight leading-tight text-text-heading mb-16 text-center">
        The Engineering Blog
      </h2>
      
      <div class="flex flex-col gap-8">
        {posts.length === 0 ? (
          <p class="text-text-body text-center py-12">No posts found.</p>
        ) : (
          posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group border border-surface/50 bg-primary-base p-6 md:p-10 flex flex-col md:flex-row hover:border-accent/50 transition-colors gap-6 relative overflow-hidden">
              {post.featuredImage && (
                <div class="md:w-1/3 overflow-hidden border border-surface/30">
                  <img 
                    src={post.featuredImage.node.sourceUrl} 
                    alt={post.featuredImage.node.altText || post.title} 
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover aspect-video group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
              )}
              
              <div class="flex-1 flex flex-col justify-center">
                <time class="text-xs font-body uppercase tracking-widest text-text-body/70 mb-3 block">
                  {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <h3 class="text-2xl md:text-3xl font-heading font-bold text-text-heading group-hover:text-accent transition-colors mb-4">
                  {post.title}
                </h3>
                
                {/* WordPress excerpt comes back wrapped in <p> tags, so we render it safely */}
                <div class="text-lg text-text-body leading-relaxed mb-6 line-clamp-3" set:html={post.excerpt} />
                
                <div class="mt-auto inline-flex items-center text-accent font-bold uppercase tracking-widest text-sm group-hover:text-white transition-colors">
                  Read Protocol
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-2 group-hover:translate-x-1 transition-transform">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </div>
              </div>
            </a>
          ))
        )}
      </div>
    </section>

    <Footer />
  </main>
</Layout>
