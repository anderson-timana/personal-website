---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const links = [
  {
    title: "LinkedIn",
    context: "Professional updates and technical insights.",
    url: "https://www.linkedin.com/in/anderson-rairt-timana-solier/"
  },
  {
    title: "Xing",
    context: "Professional networking and connections.",
    url: "https://www.xing.com/profile/AndersonRairt_TimanaSolier/"
  },
  {
    title: "YouTube",
    context: "Technical breakdowns and strategy videos.",
    url: "https://www.youtube.com/channel/UC0MoEaPVmwmX1zRqHizlNPA"
  },
  {
    title: "Instagram",
    context: "Behind-the-scenes and personal updates.",
    url: "https://www.instagram.com/anderson.timana.s/"
  },
  {
    title: "Facebook",
    context: "General updates and community interaction.",
    url: "https://www.facebook.com/andersonrairt.timanasolier"
  },
  {
    title: "GitHub",
    context: "Open-source code and technical blueprints.",
    url: "https://github.com/anderson-timana"
  },
  {
    title: "Case Studies",
    context: "A portfolio of my technical rescue audits.",
    url: "/case-studies"
  }
];
---

<Layout title="Links | Anderson Timana" description="Links to my professional profiles, technical projects, and case studies.">
  
  <main id="main-content" class="pt-16 md:pt-24 min-h-screen flex flex-col items-center">
    
    <section class="max-w-2xl w-full mx-auto p-4 md:p-8 flex-grow flex flex-col items-center text-center">
      
      <!-- Profile Block -->
      <div class="mb-12 flex flex-col items-center">
        <a href="/" class="font-heading font-bold text-4xl mb-6 text-text-heading hover:text-accent transition-colors">AT.</a>
        
        <!-- Portal Intent (H1 | VR3) -->
        <h1 class="text-xs md:text-sm font-body font-medium uppercase tracking-[0.1em] text-accent mb-4">
          Connect with me
        </h1>
        
        <p class="text-text-body">Links & Resources</p>
      </div>

      <!-- Links List -->
      <div class="flex flex-col gap-6 w-full">
        {links.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="group border border-surface/50 bg-surface/10 hover:border-accent hover:bg-surface/30 transition-all p-6 flex flex-col items-center text-center">
            
            <h2 class="text-2xl font-heading font-bold text-text-heading group-hover:text-accent transition-colors mb-2">
              {link.title}
            </h2>
            
            <p class="text-text-body text-sm max-w-sm mx-auto">
              {link.context}
            </p>
            
          </a>
        ))}
      </div>
      
    </section>

    <!-- Simple footer for links page -->
    <footer class="w-full py-8 text-center text-text-body text-xs opacity-60">
      &copy; {new Date().getFullYear()} Anderson Timana. Technical Strategy & Development.
    </footer>
  </main>

</Layout>
