---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/homepage/Hero.astro';
import TheLeak from '../components/homepage/TheLeak.astro';
import DigitalStone from '../components/homepage/DigitalStone.astro';
import TheLever from '../components/homepage/TheLever.astro';
import TheGateway from '../components/homepage/TheGateway.astro';
import Footer from '../components/Footer.astro';
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://andersontimana.me/#person",
      "name": "Anderson Timana",
      "url": "https://andersontimana.me",
      "jobTitle": "Fractional CMO & CTO",
      "description": "Digital Infrastructure Strategist & External CTO helping startups close the gap between marketing and technical execution.",
      "sameAs": [
        "https://linkedin.com/in/andersontimana"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://andersontimana.me/#website",
      "url": "https://andersontimana.me",
      "name": "Anderson Timana - Fractional CMO & CTO",
      "publisher": { "@id": "https://andersontimana.me/#person" }
    },
    {
      "@type": "ProfessionalService",
      "@id": "https://andersontimana.me/#service",
      "name": "Anderson Timana Consulting",
      "url": "https://andersontimana.me",
      "image": "https://andersontimana.me/og-image.png",
      "description": "I help founders who know their startup has unleveraged potential by bridging the gap between technical infrastructure and marketing growth.",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "DE"
      }
    }
  ]
};
---

<Layout 
  title="Anderson Timana - Fractional CMO & CTO for Startups" 
  description='My expertise allows me to close the gap generated by marketing agencies and technical teams for exponential growth.'
  structuredData={structuredData}
>
	<Navigation />
	<main id="main-content" class="w-full relative">
		<Hero />
		<TheLeak />
		<DigitalStone />
		<TheLever />
		<TheGateway />
		<Footer />
	</main>
</Layout>

<style>
  /* Enable snapping on the root level for native keyboard support - Desktop only */
  @media (min-width: 768px) {
    :global(html) {
      scroll-snap-type: y mandatory;
    }
  }
</style>
