---
interface Props {
  type?: 'freelancer' | 'cmo';
}

const { type = 'cmo' } = Astro.props;

const commonSocials = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/anderson-rairt-timana-solier/' },
  { label: 'Xing', href: 'https://www.xing.com/profile/AndersonRairt_TimanaSolier/' },
  { label: 'GitHub', href: 'https://github.com/anderson-timana' },
];

const freelancerSocials = [
  { label: 'Freelancermap', href: 'https://www.freelancermap.de/profil/full-stack-marketer-und-wordpress-developer' },
  { label: 'Upwork', href: 'https://www.upwork.com/freelancers/~011be30ff1577c7e7c' },
  { label: 'Fiverr', href: 'https://www.fiverr.com/sellers/rairtts/' },
];

const cmoSocials = [
  { label: 'Collaeb', href: 'https://app.collaeb.io/users/anderson-timana' },
  { label: 'Ycombinator', href: 'https://www.ycombinator.com/cofounder-matching' },
];

const socials = [...commonSocials, ...(type === 'freelancer' ? freelancerSocials : cmoSocials)];

const internalLinks = [
  { label: 'Services', href: '/services' },
  { label: 'Case Studies', href: '/case-studies' },
  { label: 'Free Tools', href: '/free-tools' },
  { label: 'Web Development', href: '/web-development' },
  { label: 'Blog', href: '/blog' },
  { label: 'About Me', href: '/about-me' },
];

const currentYear = new Date().getFullYear();
---

<footer class="w-full bg-primary-base border-t border-surface/50 py-12 md:py-20 px-4 md:px-8 snap-center shrink-0">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 md:gap-8">
    
    <!-- Brand & Copyright -->
    <div class="flex flex-col space-y-6">
      <a href="/" class="font-heading font-bold text-3xl text-text-heading hover:text-accent transition-colors">AT.</a>
      <p class="text-text-body/70 text-sm max-w-xs leading-relaxed">
        Expert Technical Guidance. Building high-performance website foundations and reliable infrastructure for founders.
      </p>
      <div class="text-xs text-text-body/50 uppercase tracking-widest font-bold">
        &copy; {currentYear} Anderson Timana.<br/>All rights reserved.
      </div>
    </div>

    <!-- Internal Links -->
    <div class="flex flex-col space-y-6">
      <h3 class="text-xs font-body font-bold uppercase tracking-[0.2em] text-accent">Navigation</h3>
      <ul class="flex flex-col space-y-3">
        {internalLinks.map((link) => (
          <li>
            <a href={link.href} class="text-text-body hover:text-accent transition-colors text-sm underline underline-offset-4 decoration-surface hover:decoration-accent decoration-2">
              {link.label}
            </a>
          </li>
        ))}
        <!--<li>
          <a href="/links" class="text-text-body hover:text-accent transition-colors text-sm underline underline-offset-4 decoration-surface hover:decoration-accent decoration-2">
            Links
          </a>
        </li>-->
      </ul>
    </div>

    <!-- Social Links / Find me in -->
    <div class="flex flex-col space-y-6">
      <h3 class="text-xs font-body font-bold uppercase tracking-[0.2em] text-accent">
        {type === 'cmo' ? 'Find me in' : 'Professional Channels'}
      </h3>
      <ul class="flex flex-col space-y-3">
        {socials.map((social) => (
          <li>
            <a href={social.href} target="_blank" rel="noopener noreferrer" class="text-text-body hover:text-accent transition-colors text-sm inline-flex items-center gap-2">
              {social.label}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="opacity-50">
                <path d="M7 17L17 7M17 7H7M17 7V17"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Legal Compliance -->
    <div class="flex flex-col space-y-6">
      <h3 class="text-xs font-body font-bold uppercase tracking-[0.2em] text-accent">Legal Compliance</h3>
      <p class="text-text-body/70 text-sm">
        Operating with full technical transparency and regulatory alignment.
      </p>
      <ul class="flex flex-col space-y-3">
        <li>
          <a href="/terms-and-conditions" class="text-text-body hover:text-accent transition-colors text-sm underline underline-offset-4 decoration-surface hover:decoration-accent decoration-2">
            Terms & Conditions (AGB)
          </a>
        </li>
        <li>
          <a href="/privacy-policy" class="text-text-body hover:text-accent transition-colors text-sm underline underline-offset-4 decoration-surface hover:decoration-accent decoration-2">
            Privacy Policy (Datenschutzerklärung)
          </a>
        </li>
        <li>
          <a href="/impressum" class="text-text-body hover:text-accent transition-colors text-sm underline underline-offset-4 decoration-surface hover:decoration-accent decoration-2">
            Legal Notice (Impressum)
          </a>
        </li>
      </ul>
    </div>

  </div>
</footer>
