---
interface Props {
  insuranceService: any;
}

const { insuranceService } = Astro.props;
---

<section id="insurance" class="min-h-screen w-full flex items-center justify-center p-4 md:p-8 snap-start relative border-t border-surface/30 section-pt">
  <div class="max-w-4xl mx-auto w-full text-center">
    {insuranceService && (
      <>
        <h2 class="text-xs md:text-sm font-body font-medium uppercase tracking-[0.1em] text-accent mb-6">Peace of Mind Guaranteed</h2>
        <h3 class="text-4xl md:text-5xl font-heading font-bold text-text-heading mb-8">Your Investment, Protected.</h3>
        <p class="text-text-body text-lg leading-relaxed mb-12 max-w-2xl mx-auto">
          I don't just build and walk away. My priority is ensuring your digital infrastructure remains a high-performing asset long after launch, protecting it from breaking changes and security threats.
        </p>
        
        <div class="border border-accent/30 bg-primary-base/50 p-8 md:p-12 max-w-2xl mx-auto flex flex-col md:flex-row items-center gap-8 text-left group hover:border-accent transition-colors">
          <div class="w-16 h-16 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0 text-accent group-hover:scale-110 transition-transform">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <div>
            <h4 class="text-2xl font-heading font-bold text-text-heading mb-2">{insuranceService.data.serviceTitle}</h4>
            <p class="text-text-body mb-4">{insuranceService.data.scope}</p>
            <a href={`/web-development/${insuranceService.slug}`} class="text-accent uppercase tracking-widest font-bold text-sm hover:text-white transition-colors flex items-center gap-2">
              View Protection Details &rarr;
            </a>
          </div>
        </div>
      </>
    )}
  </div>
</section>
